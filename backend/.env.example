# Society Service App - Dashboard Configuration

# Server Port (Default is 5000)
PORT=5000

# MongoDB URI (Update this with your Atlas URI)
# Example: mongodb+srv://admin:password@cluster0.mongodb.net/dbname
MONGO_URI=mongodb+srv://admin:admin123@cluster0.gjw6cgx.mongodb.net/society-app?retryWrites=true&w=majority

# App Name
APP_NAME=Society_Service_App

# Note: If PORT=5000 is occupied, the server will automatically switch to 5001, 5002, etc.
